<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <rect width="1200" height="630" fill="#05060f"/>
  <rect x="0" y="0" width="1200" height="630" fill="url(#grad)"/>
  <defs>
    <radialGradient id="grad" cx="30%" cy="40%" r="70%">
      <stop offset="0%" stop-color="#0d0f1e"/>
      <stop offset="100%" stop-color="#05060f"/>
    </radialGradient>
  </defs>
  <!-- Glow -->
  <ellipse cx="900" cy="200" rx="400" ry="300" fill="rgba(79,140,255,0.06)"/>
  <ellipse cx="200" cy="500" rx="300" ry="200" fill="rgba(167,139,250,0.05)"/>
  <!-- Logo mark -->
  <rect x="80" y="80" width="56" height="56" rx="12" fill="#0d0f1e" stroke="#1a1d35" stroke-width="1"/>
  <text x="108" y="120" text-anchor="middle" font-family="Arial,sans-serif" font-weight="700" font-size="32" fill="#4f8cff">T</text>
  <!-- Brand name -->
  <text x="80" y="230" font-family="Arial,sans-serif" font-weight="700" font-size="64" fill="#f0f4ff">tankrich.com</text>
  <!-- Tagline -->
  <text x="80" y="310" font-family="Arial,sans-serif" font-weight="400" font-size="28" fill="#8892b0">Turning AI Into Business Outcomes</text>
  <!-- Sub -->
  <text x="80" y="380" font-family="Arial,sans-serif" font-weight="400" font-size="20" fill="#4f8cff">AI Consulting · Products · Automation · Assistants</text>
  <!-- Bottom tag -->
  <text x="80" y="560" font-family="Arial,sans-serif" font-weight="400" font-size="16" fill="#8892b0">Vivek Bothra · Sydney, Australia</text>
  <!-- Live badge -->
  <rect x="80" y="430" width="200" height="36" rx="18" fill="rgba(34,211,165,0.1)" stroke="rgba(34,211,165,0.3)" stroke-width="1"/>
  <circle cx="108" cy="448" r="5" fill="#22d3a5"/>
  <text x="122" y="453" font-family="Arial,sans-serif" font-weight="600" font-size="14" fill="#22d3a5">Available Now</text>
</svg>
