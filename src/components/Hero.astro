<section id="hero" class="hero-section relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Starfield layers -->
  <div class="stars-layer stars-slow" aria-hidden="true"></div>
  <div class="stars-layer stars-fast" aria-hidden="true"></div>

  <!-- Glow orbs -->
  <div class="orb orb-blue" aria-hidden="true"></div>
  <div class="orb orb-violet" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium mb-8" style="background: rgba(79,140,255,0.1); border: 1px solid rgba(79,140,255,0.2); color: #4f8cff;">
      <span class="w-2 h-2 rounded-full animate-pulse" style="background: #22d3a5;"></span>
      Available for new projects
    </div>

    <h1 class="hero-headline font-bold tracking-tight mb-6" style="color: #f0f4ff;">
      Turning AI Into<br />
      <span class="hero-gradient-text">Business Outcomes</span>
    </h1>

    <p class="text-lg md:text-xl mb-10 max-w-2xl mx-auto" style="color: #8892b0; line-height: 1.7;">
      I help businesses and solopreneurs deploy practical AI — from social automation to intelligent dashboards and 24/7 AI assistants.
    </p>

    <p class="text-sm font-medium tracking-wider mb-10" style="color: #4f8cff; letter-spacing: 0.1em;">
      CONSULTING · PRODUCTS · AUTOMATION · AI ASSISTANTS
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#products" class="btn-primary px-8 py-4 rounded-lg font-semibold text-base transition-all duration-200">
        See My Work
      </a>
      <a href="https://wa.me/919352194655" target="_blank" rel="noopener noreferrer" class="btn-secondary px-8 py-4 rounded-lg font-semibold text-base transition-all duration-200 flex items-center justify-center gap-2">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Let's Talk
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2" style="color: #8892b0;">
    <span class="text-xs tracking-widest">SCROLL</span>
    <div class="scroll-arrow"></div>
  </div>
</section>

<style>
  .hero-section {
    background: #05060f;
  }

  .hero-headline {
    font-size: clamp(40px, 7vw, 64px);
    line-height: 1.1;
  }

  .hero-gradient-text {
    background: linear-gradient(135deg, #4f8cff 0%, #a78bfa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Starfield */
  .stars-layer {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 10% 15%, rgba(255,255,255,0.8) 0%, transparent 100%),
      radial-gradient(1px 1px at 25% 40%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 40% 10%, rgba(255,255,255,0.9) 0%, transparent 100%),
      radial-gradient(1px 1px at 55% 60%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 70% 25%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 80% 75%, rgba(255,255,255,0.8) 0%, transparent 100%),
      radial-gradient(1px 1px at 90% 45%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 15% 80%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 35% 90%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 60% 85%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 75% 55%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 92% 20%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 5% 55%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 48% 35%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 63% 70%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 88% 90%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 22% 65%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 45% 50%, rgba(255,255,255,0.3) 0%, transparent 100%),
      radial-gradient(1px 1px at 30% 20%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 68% 42%, rgba(255,255,255,0.6) 0%, transparent 100%);
    background-size: 100% 100%;
  }

  .stars-slow {
    animation: drift-slow 120s linear infinite;
    opacity: 0.8;
  }

  .stars-fast {
    background-size: 50% 50%;
    animation: drift-fast 80s linear infinite;
    opacity: 0.5;
  }

  @keyframes drift-slow {
    0% { transform: translateY(0px) translateX(0px); }
    50% { transform: translateY(-20px) translateX(10px); }
    100% { transform: translateY(0px) translateX(0px); }
  }

  @keyframes drift-fast {
    0% { transform: translateY(0px) translateX(0px); }
    50% { transform: translateY(-35px) translateX(-15px); }
    100% { transform: translateY(0px) translateX(0px); }
  }

  /* Glow Orbs */
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .orb-blue {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(79,140,255,0.12) 0%, transparent 70%);
    top: -100px;
    right: -100px;
    animation: orb-pulse 8s ease-in-out infinite;
  }

  .orb-violet {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(167,139,250,0.1) 0%, transparent 70%);
    bottom: 0;
    left: -80px;
    animation: orb-pulse 10s ease-in-out infinite reverse;
  }

  @keyframes orb-pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.1); }
  }

  /* Buttons */
  .btn-primary {
    background: #4f8cff;
    color: #05060f;
    font-weight: 600;
    box-shadow: 0 0 20px rgba(79,140,255,0.3);
  }

  .btn-primary:hover {
    background: #6ba3ff;
    box-shadow: 0 0 30px rgba(79,140,255,0.5);
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: rgba(79,140,255,0.08);
    color: #f0f4ff;
    border: 1px solid rgba(79,140,255,0.25);
  }

  .btn-secondary:hover {
    background: rgba(79,140,255,0.15);
    border-color: rgba(79,140,255,0.4);
    transform: translateY(-1px);
  }

  /* Scroll arrow */
  .scroll-arrow {
    width: 20px;
    height: 20px;
    border-right: 2px solid #8892b0;
    border-bottom: 2px solid #8892b0;
    transform: rotate(45deg);
    animation: bounce-down 2s ease-in-out infinite;
    margin-top: -8px;
  }

  @keyframes bounce-down {
    0%, 100% { transform: rotate(45deg) translateY(0); opacity: 0.6; }
    50% { transform: rotate(45deg) translateY(4px); opacity: 1; }
  }
</style>
