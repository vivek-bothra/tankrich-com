---
---
<section id="contact" class="py-24 px-6 relative overflow-hidden">
  <!-- Glow background -->
  <div class="contact-glow" aria-hidden="true"></div>
  <div class="section-divider" aria-hidden="true"></div>

  <div class="max-w-3xl mx-auto text-center relative z-10">
    <span class="text-sm font-semibold tracking-widest uppercase mb-4 block" style="color: #4f8cff;">Get In Touch</span>
    <h2 class="font-bold mb-6" style="color: #f0f4ff; font-size: clamp(28px, 5vw, 42px); line-height: 1.2;">Ready to Put AI<br />to Work?</h2>
    <p class="text-lg mb-10 max-w-lg mx-auto" style="color: #8892b0; line-height: 1.7;">
      Let's talk about your business. No jargon, no fluff — just practical AI that delivers results.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="https://wa.me/61449924670"
        target="_blank"
        rel="noopener noreferrer"
        class="whatsapp-btn px-8 py-4 rounded-xl font-semibold text-base transition-all duration-200 inline-flex items-center gap-3"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Message Me on WhatsApp →
      </a>
    </div>

    <p class="mt-6 text-sm" style="color: #8892b0;">
      Prefer email? <a href="mailto:hello@tankrich.com" class="underline underline-offset-2 transition-colors hover:text-white" style="color: #8892b0;">hello@tankrich.com</a>
    </p>
  </div>
</section>

<style>
  .contact-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(79,140,255,0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .section-divider {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(167,139,250,0.2), transparent);
  }

  .whatsapp-btn {
    background: #25d366;
    color: #fff;
    box-shadow: 0 0 30px rgba(37,211,102,0.2);
  }

  .whatsapp-btn:hover {
    background: #20bd5a;
    box-shadow: 0 0 40px rgba(37,211,102,0.35);
    transform: translateY(-2px);
  }
</style>
