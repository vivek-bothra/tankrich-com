---
import type { Product } from '../data/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const isAvailable = product.status === 'available';
const whatsappUrl = 'https://wa.me/61449924670';
const hasLiveUrl = !!product.liveUrl;
const isInfoOnly = product.modalType === 'info';
const modalId = `modal-${product.id}`;
---

<div class="product-card rounded-2xl p-6 flex flex-col gap-4 transition-all duration-300">
  <!-- Header -->
  <div class="flex items-start justify-between gap-4">
    <div class="text-4xl leading-none">{product.icon}</div>
    <span class={`status-badge text-xs font-semibold px-3 py-1 rounded-full ${isAvailable ? 'badge-live' : 'badge-dev'}`}>
      {isAvailable ? '● Available Now' : '◌ In Development'}
    </span>
  </div>

  <h3 class="text-lg font-bold leading-snug" style="color: #f0f4ff;">{product.name}</h3>
  <p class="text-sm leading-relaxed flex-1" style="color: #8892b0;">{product.description}</p>

  <div class="flex flex-wrap gap-2">
    {product.tags.map(tag => (
      <span class="tag-pill text-xs px-2.5 py-1 rounded-full font-medium">{tag}</span>
    ))}
  </div>

  <!-- CTA -->
  {hasLiveUrl ? (
    <button
      data-modal={modalId}
      class="cta-btn mt-2 px-5 py-2.5 rounded-lg text-sm font-semibold text-center transition-all duration-200 w-full cursor-pointer"
    >
      {product.ctaText} →
    </button>
  ) : (
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="cta-btn mt-2 px-5 py-2.5 rounded-lg text-sm font-semibold text-center transition-all duration-200 inline-block"
    >
      {product.ctaText} →
    </a>
  )}
</div>

<!-- Modal -->
{hasLiveUrl && (
  <div id={modalId} class={`modal-overlay ${isInfoOnly ? 'info-modal' : ''}`} role="dialog" aria-modal="true" aria-label={product.name}>
    <div class={`modal-container ${isInfoOnly ? 'modal-container--info' : 'modal-container--iframe'}`}>

      <!-- Modal header -->
      <div class="modal-header">
        <div class="flex items-center gap-3">
          <span class="text-2xl flex-shrink-0">{product.icon}</span>
          <div>
            <h3 class="font-bold text-base" style="color: #f0f4ff;">{product.name}</h3>
            <span class={`text-xs font-semibold ${isAvailable ? 'text-live' : 'text-muted'}`}>
              {isAvailable ? '● Available Now' : '◌ In Development'}
            </span>
          </div>
        </div>
        <button class="modal-close" data-close={modalId} aria-label="Close">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Service info panel — always shown -->
      <div class="service-info">
        <p class="text-sm leading-relaxed mb-4" style="color: #8892b0;">{product.description}</p>

        {product.bullets && product.bullets.length > 0 && (
          <ul class="bullet-list mb-4">
            {product.bullets.map(b => (
              <li class="flex items-start gap-2 text-sm mb-2" style="color: #8892b0;">
                <span class="bullet-dot flex-shrink-0 mt-1.5">✦</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        )}

        <div class="flex flex-wrap gap-2">
          {product.tags.map(tag => (
            <span class="tag-pill text-xs px-2.5 py-1 rounded-full font-medium">{tag}</span>
          ))}
        </div>
      </div>

      <!-- Info-only: GPT / external CTA -->
      {isInfoOnly && (
        <div class="info-cta">
          <div class="info-cta-inner rounded-xl p-6 text-center">
            <p class="text-sm mb-2 font-semibold" style="color: #f0f4ff;">Ready to try it?</p>
            <p class="text-sm mb-6" style="color: #8892b0;">This opens as a custom GPT inside ChatGPT. Click below to launch it.</p>
            <a
              href={product.liveUrl!}
              target="_blank"
              rel="noopener noreferrer"
              class="ext-btn inline-flex items-center gap-2 px-7 py-3 rounded-lg font-semibold text-sm transition-all duration-200"
            >
              Open {product.name} in ChatGPT
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
            </a>
          </div>
          <p class="text-xs text-center mt-4" style="color: #8892b0;">
            Opens in a new tab — ChatGPT account required
          </p>
        </div>
      )}

      <!-- Iframe demo -->
      {!isInfoOnly && (
        <div class="modal-iframe-wrap">
          <div class="iframe-label">
            <span class="text-xs font-medium" style="color: #8892b0;">Live Demo</span>
            <a
              href={product.liveUrl!}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs flex items-center gap-1 transition-colors hover:text-white"
              style="color: #8892b0;"
            >
              Open in new tab
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
            </a>
          </div>
          <iframe
            src={product.liveUrl!}
            class="modal-iframe"
            title={product.name}
            sandbox="allow-scripts allow-same-origin allow-forms allow-popups"
          ></iframe>
          <div class="iframe-fallback">
            <div class="text-4xl mb-4">{product.icon}</div>
            <p class="font-semibold mb-2" style="color: #f0f4ff;">Live preview not available here</p>
            <p class="text-sm mb-6" style="color: #8892b0;">This site restricts embedded previews.</p>
            <a
              href={product.liveUrl!}
              target="_blank"
              rel="noopener noreferrer"
              class="ext-btn inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm"
            >
              Open in New Tab
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
            </a>
          </div>
        </div>
      )}

    </div>
  </div>
)}

<style>
  .product-card {
    background: rgba(13, 15, 30, 0.8);
    border: 1px solid rgba(255,255,255,0.07);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .product-card:hover {
    border-color: rgba(79,140,255,0.25);
    box-shadow: 0 8px 40px rgba(79,140,255,0.12), 0 0 0 1px rgba(79,140,255,0.1);
    transform: translateY(-4px);
  }
  .badge-live { background: rgba(34,211,165,0.1); color: #22d3a5; border: 1px solid rgba(34,211,165,0.2); }
  .badge-dev  { background: rgba(136,146,176,0.1); color: #8892b0; border: 1px solid rgba(136,146,176,0.2); }
  .text-live  { color: #22d3a5; }
  .text-muted { color: #8892b0; }
  .tag-pill {
    background: rgba(79,140,255,0.08);
    color: #8892b0;
    border: 1px solid rgba(79,140,255,0.12);
  }
  .cta-btn {
    background: rgba(79,140,255,0.1);
    color: #4f8cff;
    border: 1px solid rgba(79,140,255,0.2);
  }
  .cta-btn:hover {
    background: #4f8cff;
    color: #05060f;
    border-color: #4f8cff;
    box-shadow: 0 4px 20px rgba(79,140,255,0.3);
  }

  /* Modal overlay */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(5,6,15,0.88);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  .modal-overlay.open { display: flex; }

  /* Container — iframe variant (tall) */
  .modal-container--iframe {
    background: #0d0f1e;
    border: 1px solid rgba(79,140,255,0.2);
    border-radius: 16px;
    width: 100%;
    max-width: 960px;
    height: 88vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,0.7), 0 0 0 1px rgba(79,140,255,0.08);
    animation: modal-in 0.2s ease;
  }

  /* Container — info-only variant (compact) */
  .modal-container--info {
    background: #0d0f1e;
    border: 1px solid rgba(79,140,255,0.2);
    border-radius: 16px;
    width: 100%;
    max-width: 560px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,0.7), 0 0 0 1px rgba(79,140,255,0.08);
    animation: modal-in 0.2s ease;
  }

  @keyframes modal-in {
    from { opacity: 0; transform: scale(0.97) translateY(10px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    flex-shrink: 0;
    gap: 12px;
  }

  .modal-close {
    color: #8892b0;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    width: 34px; height: 34px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: all 0.15s ease;
    flex-shrink: 0;
  }
  .modal-close:hover { background: rgba(255,255,255,0.1); color: #f0f4ff; }

  /* Service info panel */
  .service-info {
    padding: 20px 20px 16px;
    flex-shrink: 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .bullet-dot { color: #4f8cff; font-size: 8px; }

  /* Info-only CTA area */
  .info-cta { padding: 20px; }
  .info-cta-inner {
    background: rgba(79,140,255,0.05);
    border: 1px solid rgba(79,140,255,0.12);
  }

  /* Iframe section */
  .modal-iframe-wrap { flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative; }

  .iframe-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 16px;
    background: rgba(255,255,255,0.02);
    border-bottom: 1px solid rgba(255,255,255,0.04);
    flex-shrink: 0;
  }

  .modal-iframe { width: 100%; flex: 1; border: none; background: #fff; min-height: 0; }

  .iframe-fallback {
    display: none;
    position: absolute;
    inset: 0;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    text-align: center;
    padding: 40px;
    background: #0d0f1e;
  }
  .iframe-fallback.visible { display: flex; }

  .ext-btn {
    background: #4f8cff;
    color: #05060f;
    box-shadow: 0 4px 20px rgba(79,140,255,0.3);
  }
  .ext-btn:hover {
    background: #6ba3ff;
    box-shadow: 0 6px 28px rgba(79,140,255,0.45);
    transform: translateY(-1px);
  }
</style>

<script>
  document.querySelectorAll('[data-modal]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.modal!;
      const modal = document.getElementById(id);
      if (!modal) return;
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';

      const iframe = modal.querySelector('iframe') as HTMLIFrameElement | null;
      const fallback = modal.querySelector('.iframe-fallback') as HTMLElement | null;
      if (iframe && fallback) {
        iframe.addEventListener('load', () => {
          try {
            const doc = iframe.contentDocument;
            if (!doc || doc.body?.innerHTML === '') showFallback(iframe, fallback);
          } catch { showFallback(iframe, fallback); }
        }, { once: true });
        iframe.addEventListener('error', () => showFallback(iframe, fallback), { once: true });
      }
    });
  });

  document.querySelectorAll('[data-close]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.close!;
      document.getElementById(id)?.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', e => {
      if (e.target === overlay) {
        (overlay as HTMLElement).classList.remove('open');
        document.body.style.overflow = '';
      }
    });
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.modal-overlay.open').forEach(m => {
        m.classList.remove('open');
        document.body.style.overflow = '';
      });
    }
  });

  function showFallback(iframe: HTMLIFrameElement, fallback: HTMLElement) {
    iframe.style.display = 'none';
    fallback.classList.add('visible');
  }
</script>
